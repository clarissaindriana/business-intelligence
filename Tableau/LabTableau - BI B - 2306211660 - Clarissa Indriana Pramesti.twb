      <column caption='Access to Resources' datatype='string' name='[Access_to_Resources]' role='dimension' type='nominal' />
      <column caption='Attendance (bin)' datatype='integer' name='[Attendance (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='1' formula='[Attendance]' peg='0' size='10' />
      </column>
      <column datatype='integer' name='[Attendance]' role='measure' type='quantitative' />
      <column caption='Performance Category' datatype='string' name='[Calculation_0422886628417540]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Exam_Score] &gt;= 75 THEN &quot;High Performer&quot;&#10;ELSE &quot;Low Performer&quot;&#10;END' />
      </column>
      <column caption='Study Habit Balance' datatype='string' name='[Calculation_0422886631206917]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Hours_Studied] &gt;= 5 AND [Sleep_Hours] &gt;= 7 THEN &quot;Balanced&quot;&#10;ELSE &quot;Unbalanced&quot;&#10;END' />
      </column>
      <column caption='Distance from Home' datatype='string' name='[Distance_from_Home]' role='dimension' type='nominal' />
      <column caption='Exam Score (bin)' datatype='integer' name='[Exam Score (bin)]' role='dimension' type='ordinal'>
